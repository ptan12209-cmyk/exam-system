{
  "name": "studyhub-remotion",
  "version": "2.0.0",
  "private": true,
  "description": "StudyHub Full marketing video — scene-synced TTS, Remotion best practices",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "voice:generate": "node scripts/generate-voice.mjs",
    "render:full": "remotion render src/index.ts StudyHubFull out/studyhub-full.mp4",
    "render:full:with-voice": "npm run voice:generate && npm run render:full",
    "upgrade": "remotion upgrade"
  },
  "dependencies": {
    "@remotion/cli": "4.0.489",
    "@remotion/google-fonts": "^4.0.489",
    "@remotion/media-utils": "^4.0.489",
    "@remotion/renderer": "4.0.489",
    "@remotion/transitions": "^4.0.489",
    "@remotion/zod-types": "4.0.489",
    "@types/qrcode": "^1.5.6",
    "edge-tts": "^1.0.1",
    "node-edge-tts": "^1.2.10",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.489"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/web": "^0.0.246",
    "typescript": "^5.8.3"
  }
}
