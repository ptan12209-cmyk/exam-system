# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# remotion (video production — keep local, do not commit)
/remotion/

# hyperframes compositions, renders, cache
/videos/
**/.hyperframes/
**/.thumbnails/
*.hyb

# marketing video scripts / production notes (local only)
/docs/marketing/

# remotion / hyperframes agent skills (local tooling)
.agents/skills/remotion-skills/
.agents/skills/hyperframes*/
.agents/skills/embedded-captions/
.agents/skills/faceless-explainer/
.agents/skills/general-video/
.agents/skills/media-use/
.agents/skills/motion-graphics/
