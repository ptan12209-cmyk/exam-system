.agents/skills/slideshow/
.agents/skills/talking-head-recut/
.agents/skills/website-to-video/
.agents/skills/figma/

# generated audit / fix reports
scripts/*-report.json
scripts/dupe-lessons-to-delete.json


# production
/build

# misc
.DS_Store
*.pem

